{
  "name": "example-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10",
      "onFail": "error"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check": "npm run lint && npm run test",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "node --test"
  }
}
